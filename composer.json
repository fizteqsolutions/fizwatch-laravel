{
    "name": "fizteqsolutions/fizwatch-laravel",
    "description": "Laravel client package for FizWatch error tracking",
    "keywords": ["laravel", "error-tracking", "fizwatch", "exception-handler"],
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "illuminate/console": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "FizWatch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FizWatch\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FizWatch\\FizWatchServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "orchestra/testbench": "^10.9|^11.0",
        "phpunit/phpunit": "^12.5"
    }
}
